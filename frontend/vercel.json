{
  "routes": [
    { "handle": "filesystem" },
    {
      "src": "/music-cue/assets/(.*)",
      "missing": [{ "type": "filesystem" }],
      "status": 404
    },
    {
      "src": "/music-cue/spotify/callback",
      "dest": "/music-cue/index.html"
    },
    {
      "src": "/music-cue",
      "dest": "/music-cue/index.html"
    },
    {
      "src": "/music-cue/(.*)",
      "dest": "/music-cue/index.html"
    },
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ],
  "functions": {
    "api/spotify/[...path].js": {
      "maxDuration": 60
    },
    "api/shared-libraries/index.js": {
      "maxDuration": 60
    },
    "api/shared-libraries/[...path].js": {
      "maxDuration": 60
    }
  }
}
