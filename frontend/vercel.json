{
  "rewrites": [
    {
      "source": "/music-cue/spotify/callback",
      "destination": "/music-cue/index.html"
    },
    {
      "source": "/music-cue",
      "destination": "/music-cue/index.html"
    },
    {
      "source": "/music-cue/:path((?!.*\\..*).*)",
      "destination": "/music-cue/index.html"
    },
    {
      "source": "/:path((?!.*\\..*).*)",
      "destination": "/index.html"
    }
  ],
  "functions": {
    "api/spotify/[...path].js": {
      "maxDuration": 60
    },
    "api/shared-libraries/index.js": {
      "maxDuration": 60
    },
    "api/shared-libraries/[...path].js": {
      "maxDuration": 60
    }
  }
}
