# Apple Music (existing) — no env vars required; uses Music.app on macOS.

# Spotify — create an app at https://developer.spotify.com/dashboard
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
# Must match a Redirect URI in your Spotify app settings.
# Local dev: Spotify does not allow "localhost" — use the loopback IP instead:
SPOTIFY_REDIRECT_URI=http://127.0.0.1:5174/spotify/callback
# Production (Vercel): set to your deployed callback, e.g.
# SPOTIFY_REDIRECT_URI=https://yourdomain.com/music-cue/spotify/callback
# Or set SITE_URL=https://yourdomain.com and the server derives the callback URI.

# Required in production for sealing Spotify session cookies (use a long random string).
SPOTIFY_SESSION_SECRET=

# Required in production for shared Spotify libraries (guests load published snapshots from here).
#
# Recommended: Cloudflare R2 (free tier: 10 GB storage, no egress fees). Create a bucket + API token
# with Object Read & Write, then set:
# SHARED_LIBRARY_STORAGE=s3
# SHARED_LIBRARY_S3_BUCKET=your-bucket-name
# SHARED_LIBRARY_S3_ENDPOINT=https://<account_id>.r2.cloudflarestorage.com
# SHARED_LIBRARY_S3_ACCESS_KEY_ID=
# SHARED_LIBRARY_S3_SECRET_ACCESS_KEY=
# SHARED_LIBRARY_S3_REGION=auto
#
# Legacy: Vercel Blob (if your store is not suspended)
# BLOB_READ_WRITE_TOKEN=

# Optional server port (default 3847)
# PORT=3847
